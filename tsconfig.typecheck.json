{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "react", "react-dom"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "functions/src/permissionCatalog.js",
    "functions/src/services/permissionEngine.js",
    "functions/src/services/roleAuthorization.js",
    "functions/src/callables/permissions.js",
    "functions/src/callables/studentImports.js",
    "functions/src/callables/roles.js",
    "functions/src/validation/schemas.js",
    "src/services/adminUserService.js",
    "src/components/Students/BulkStudentImportWizard.jsx",
    "src/components/Shared/PermissionsMenu.jsx"
  ]
}
