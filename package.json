{
  "name": "zoko-master",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:emulator",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:security": "node --test --test-concurrency=1 tests/security/*.test.js",
    "test:emulator": "node scripts/run-security-emulators.mjs",
    "test:pdf": "node --test tests/pdf/*.test.js",
    "check": "npm run lint && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "firebase": "^12.10.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.24.0",
    "globals": "^17.4.0",
    "vite": "^8.0.0"
  },
  "overrides": {
    "@hono/node-server": "^2.0.5",
