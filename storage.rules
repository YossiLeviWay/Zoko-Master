rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function activeUser() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && (!('accountStatus' in currentUser()) || currentUser().accountStatus == 'active');
    }

    function isGlobalAdmin() {
      return signedIn()
        && request.auth.token.keys().hasAny(['global_admin'])
        && request.auth.token.global_admin == true;
    }

    function isSchoolMember(schoolId) {
      return activeUser() && (
        isGlobalAdmin()
        || (currentUser().schoolId is string && currentUser().schoolId == schoolId)
        || (currentUser().schoolIds is list && schoolId in currentUser().schoolIds)
      );
    }

    function isSchoolPrincipal(schoolId) {
      return isSchoolMember(schoolId) && currentUser().role == 'principal';
    }

    function hasPermission(schoolId, permission) {
      return isGlobalAdmin()
        || isSchoolPrincipal(schoolId)
        || (
          isSchoolMember(schoolId)
          && currentUser().permissions is map
          && permission in currentUser().permissions
          && currentUser().permissions[permission] == true
        );
    }

    function rolePermission(schoolId, permission) {
      return 'rolePermissionsBySchool' in currentUser()
        && currentUser().rolePermissionsBySchool is map
        && schoolId in currentUser().rolePermissionsBySchool
        && currentUser().rolePermissionsBySchool[schoolId] is map
        && permission in currentUser().rolePermissionsBySchool[schoolId]
        && currentUser().rolePermissionsBySchool[schoolId][permission] == true;
    }

    function classRolePermission(schoolId, permission, classId) {
      return classId is string
        && 'classRolePermissionsBySchool' in currentUser()
        && currentUser().classRolePermissionsBySchool is map
        && schoolId in currentUser().classRolePermissionsBySchool
        && currentUser().classRolePermissionsBySchool[schoolId] is map
        && permission in currentUser().classRolePermissionsBySchool[schoolId]
        && currentUser().classRolePermissionsBySchool[schoolId][permission] is list
        && classId in currentUser().classRolePermissionsBySchool[schoolId][permission];
    }

    function personalFileStudent(schoolId, studentId) {
      let studentsCollection = 'students_' + schoolId;
      return firestore.get(
        /databases/(default)/documents/$(studentsCollection)/$(studentId)
      ).data;
    }

    function directPermission(permission) {
      return currentUser().permissions is map
        && permission in currentUser().permissions
        && currentUser().permissions[permission] == true;
    }

    function canViewPersonalFile(schoolId, studentId) {
      let student = personalFileStudent(schoolId, studentId);
      return isSchoolMember(schoolId) && (
        isGlobalAdmin()
        || currentUser().role == 'principal'
        || directPermission('personalFile.view')
        || directPermission('personalFile.manage')
        || rolePermission(schoolId, 'personalFile.view')
        || rolePermission(schoolId, 'personalFile.manage')
        || classRolePermission(schoolId, 'personalFile.view', student.classId)
        || classRolePermission(schoolId, 'personalFile.manage', student.classId)
      );
    }

    function canUploadPersonalFile(schoolId, studentId) {
      let student = personalFileStudent(schoolId, studentId);
      return canViewPersonalFile(schoolId, studentId) && (
        isGlobalAdmin()
        || currentUser().role == 'principal'
        || directPermission('personalFile.upload')
        || rolePermission(schoolId, 'personalFile.upload')
        || classRolePermission(schoolId, 'personalFile.upload', student.classId)
      );
    }

    function canViewCv(schoolId, studentId) {
      let student = personalFileStudent(schoolId, studentId);
      return isSchoolMember(schoolId) && (
        isGlobalAdmin()
        || currentUser().role == 'principal'
        || directPermission('cv.view')
        || directPermission('cv.create')
        || directPermission('cv.edit')
        || rolePermission(schoolId, 'cv.view')
        || rolePermission(schoolId, 'cv.create')
        || rolePermission(schoolId, 'cv.edit')
        || classRolePermission(schoolId, 'cv.view', student.classId)
        || classRolePermission(schoolId, 'cv.create', student.classId)
        || classRolePermission(schoolId, 'cv.edit', student.classId)
      );
    }

    function canExportCv(schoolId, studentId) {
      let student = personalFileStudent(schoolId, studentId);
      return canViewCv(schoolId, studentId) && (
        isGlobalAdmin()
        || currentUser().role == 'principal'
        || directPermission('cv.exportPdf')
        || rolePermission(schoolId, 'cv.exportPdf')
        || classRolePermission(schoolId, 'cv.exportPdf', student.classId)
      );
    }

    function safeGeneralUpload(filename) {
      return request.resource != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType is string
        && request.resource.contentType.matches(
          '^(image/(jpeg|png|gif|webp)|text/(plain|csv)|application/(pdf|msword|vnd\\.openxmlformats-officedocument\\..+|vnd\\.ms-excel|vnd\\.ms-powerpoint|zip))$'
        )
        && !filename.matches('(?i).+\\.(exe|dll|bat|cmd|com|msi|ps1|sh|js|mjs|html|htm|svg|jar|apk)$');
    }

    function safeImageUpload(filename, maxBytes) {
      return request.resource != null
        && request.resource.size < maxBytes
        && request.resource.contentType is string
        && request.resource.contentType.matches('^image/(jpeg|png|gif|webp)$')
        && !filename.matches('(?i).+\\.(svg|html|htm|js|mjs)$');
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && request.auth.uid in firestore.get(
          /databases/(default)/documents/conversations/$(conversationId)
        ).data.participants;
    }

    match /schools/{schoolId}/files/{fileId}/{filename} {
      allow read: if isSchoolMember(schoolId);
      allow create, update: if hasPermission(schoolId, 'files_upload')
        && safeGeneralUpload(filename);
      allow delete: if hasPermission(schoolId, 'files_delete');
    }

    match /schools/{schoolId}/chat-images/{conversationId}/{filename} {
      allow read: if isSchoolMember(schoolId) && isConversationParticipant(conversationId);
      allow create: if isSchoolMember(schoolId)
        && isConversationParticipant(conversationId)
        && safeImageUpload(filename, 10 * 1024 * 1024);
      allow update: if false;
      allow delete: if isConversationParticipant(conversationId);
    }

    match /schools/{schoolId}/students/{studentId}/personal-file/{kind}/{fileId}/{filename} {
      allow read: if canViewPersonalFile(schoolId, studentId);
      allow create: if kind in [
          'documents', 'credentials', 'experiences', 'skills', 'recommendations'
        ]
        && canUploadPersonalFile(schoolId, studentId)
        && safeGeneralUpload(filename);
      allow update, delete: if false;
    }

    match /schools/{schoolId}/students/{studentId}/cv/{documentId}/{versionId}/{exportId}/{filename} {
      allow read: if canViewCv(schoolId, studentId);
      allow create: if canExportCv(schoolId, studentId)
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf'
        && filename.matches('(?i).+\\.pdf$');
      allow update, delete: if false;
    }

    match /users/{userId}/avatars/{filename} {
      allow read: if signedIn();
      allow create, update: if request.auth.uid == userId
        && safeImageUpload(filename, 5 * 1024 * 1024);
      allow delete: if request.auth.uid == userId;
    }

    // Transitional legacy paths. Remove after the verified nested migration window.
    match /schools/{schoolId}/{folderId}/{filename} {
      allow read: if isSchoolMember(schoolId);
      allow create, update: if hasPermission(schoolId, 'files_upload')
        && safeGeneralUpload(filename);
      allow delete: if hasPermission(schoolId, 'files_delete');
    }

    match /chat_images/{conversationId}/{filename} {
      allow read: if isConversationParticipant(conversationId);
      allow create: if isConversationParticipant(conversationId)
        && safeImageUpload(filename, 10 * 1024 * 1024);
      allow update: if false;
      allow delete: if isConversationParticipant(conversationId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
