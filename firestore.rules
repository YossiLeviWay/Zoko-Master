rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasCurrentUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function activeUser() {
      return hasCurrentUser()
        && (!('accountStatus' in currentUser()) || currentUser().accountStatus == 'active');
    }

    function isGlobalAdmin() {
      return signedIn()
        && request.auth.token.keys().hasAny(['global_admin'])
        && request.auth.token.global_admin == true;
    }

    function isSchoolMember(schoolId) {
      return activeUser() && (
        isGlobalAdmin()
        || (currentUser().schoolId is string && currentUser().schoolId == schoolId)
        || (currentUser().schoolIds is list && schoolId in currentUser().schoolIds)
      );
    }

    function isSchoolPrincipal(schoolId) {
      return isSchoolMember(schoolId) && currentUser().role == 'principal';
    }

    function canViewSchoolResource(schoolId) {
      return isSchoolMember(schoolId);
    }

    function canEditSchoolResource(schoolId) {
      return isGlobalAdmin()
        || isSchoolPrincipal(schoolId)
        || (isSchoolMember(schoolId) && currentUser().role == 'editor');
    }

    function canManageSchoolUsers(schoolId) {
      return isGlobalAdmin() || isSchoolPrincipal(schoolId);
    }

    function hasPermission(schoolId, permission) {
      return canManageSchoolUsers(schoolId)
        || (
          isSchoolMember(schoolId)
          && currentUser().permissions is map
          && permission in currentUser().permissions
          && currentUser().permissions[permission] == true
        );
    }

    function hasStudentDataAccess(schoolId) {
      return activeUser() && (
        (
          request.auth.token.keys().hasAny(['global_admin'])
          && request.auth.token.global_admin == true
          && request.auth.token.keys().hasAny(['student_data_access'])
          && request.auth.token.student_data_access == true
        ) || (
          !(request.auth.token.keys().hasAny(['global_admin']) && request.auth.token.global_admin == true)
          && (
            (currentUser().schoolId is string && currentUser().schoolId == schoolId)
            || (currentUser().schoolIds is list && schoolId in currentUser().schoolIds)
          )
        )
      );
    }

    function studentPermission(permission) {
      return currentUser().permissions is map
        && permission in currentUser().permissions
        && currentUser().permissions[permission] == true;
    }

    function hasSchoolWideStudentReadPermission() {
      return studentPermission('students_view')
        || studentPermission('students_edit')
        || studentPermission('students_update')
        || studentPermission('students_archive')
        || studentPermission('students_transfer_class')
        || studentPermission('students_manage_programs')
        || studentPermission('students.promote')
        || studentPermission('classes.promote')
        || studentPermission('students.markGraduate')
        || studentPermission('students.markWithdrawn')
        || studentPermission('students.markDropout')
        || studentPermission('students.restore')
        || studentPermission('attendance_view')
        || studentPermission('attendance_edit')
        || studentPermission('attendance_create');
    }

    function hasSchoolWideClassReadPermission() {
      return hasSchoolWideStudentReadPermission()
        || studentPermission('classes_view')
        || studentPermission('classes_create')
        || studentPermission('classes_update')
        || studentPermission('classes_archive')
        || studentPermission('classes_assign_teacher')
        || studentPermission('students_create')
        || studentPermission('attendance_manage_legend')
        || studentPermission('attendance_manage_dates');
    }

    function rolePermission(schoolId, permission) {
      return 'rolePermissionsBySchool' in currentUser()
        && currentUser().rolePermissionsBySchool is map
        && schoolId in currentUser().rolePermissionsBySchool
        && currentUser().rolePermissionsBySchool[schoolId] is map
        && permission in currentUser().rolePermissionsBySchool[schoolId]
        && currentUser().rolePermissionsBySchool[schoolId][permission] == true;
    }

    function classRolePermission(schoolId, permission, classId) {
      return classId is string
        && 'classRolePermissionsBySchool' in currentUser()
        && currentUser().classRolePermissionsBySchool is map
        && schoolId in currentUser().classRolePermissionsBySchool
        && currentUser().classRolePermissionsBySchool[schoolId] is map
        && permission in currentUser().classRolePermissionsBySchool[schoolId]
        && currentUser().classRolePermissionsBySchool[schoolId][permission] is list
        && classId in currentUser().classRolePermissionsBySchool[schoolId][permission];
    }

    function hasAnyRolePermission(schoolId, permissions) {
      return 'rolePermissionsBySchool' in currentUser()
        && currentUser().rolePermissionsBySchool is map
        && schoolId in currentUser().rolePermissionsBySchool
        && currentUser().rolePermissionsBySchool[schoolId] is map
        && currentUser().rolePermissionsBySchool[schoolId].keys().hasAny(permissions);
    }

    function canViewAllStudents(schoolId) {
      return hasStudentDataAccess(schoolId) && (
        (request.auth.token.keys().hasAny(['global_admin']) && request.auth.token.global_admin == true)
        || currentUser().role == 'principal'
        || hasSchoolWideStudentReadPermission()
        || hasAnyRolePermission(schoolId, [
          'students.view', 'students.update', 'students.archive', 'students.transferClass',
          'students.promote', 'classes.promote', 'students.markGraduate',
          'students.markWithdrawn', 'students.markDropout', 'students.restore'
        ])
      );
    }

    function canManagePrograms(schoolId) {
      return hasStudentDataAccess(schoolId) && (
        currentUser().role == 'principal'
        || studentPermission('students_manage_programs')
        || studentPermission('students.managePrograms')
        || studentPermission('students_edit')
        || rolePermission(schoolId, 'students.managePrograms')
      );
    }

    function classAssignedToCurrentUser(data) {
      return (
          data.teacherId is string
          && data.teacherId == request.auth.uid
        ) || (
          data.staffIds is list
          && request.auth.uid in data.staffIds
        );
    }

    function classTaughtByCurrentUser(data) {
      return data.teacherId is string && data.teacherId == request.auth.uid;
    }

    function canViewClass(schoolId, data) {
      return hasStudentDataAccess(schoolId) && (
        classAssignedToCurrentUser(data)
        || (request.auth.token.keys().hasAny(['global_admin']) && request.auth.token.global_admin == true)
        || currentUser().role == 'principal'
        || hasSchoolWideClassReadPermission()
        || hasAnyRolePermission(schoolId, [
          'classes.view', 'classes.create', 'classes.update', 'classes.archive',
          'classes.assignTeacher', 'classes.promote', 'students.view',
          'students.create', 'students.update', 'students.transferClass'
        ])
        || ('createdBy' in data && data.createdBy is string && data.createdBy == request.auth.uid)
      );
    }

    function nestedClassExists(schoolId, classId) {
      return classId is string
        && classId.size() > 0
        && exists(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId));
    }

    function legacyClassExists(schoolId, classId) {
      let legacyClasses = 'classes_' + schoolId;
      return classId is string
        && classId.size() > 0
        && exists(/databases/$(database)/documents/$(legacyClasses)/$(classId));
    }

    function classExists(schoolId, classId) {
      return nestedClassExists(schoolId, classId) || legacyClassExists(schoolId, classId);
    }

    function studentBelongsToClass(schoolId, studentId, classId) {
      let legacyStudents = 'students_' + schoolId;
      return studentId is string
        && classId is string
        && (
          (
            exists(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId))
            && get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data.classId == classId
          ) || (
            exists(/databases/$(database)/documents/$(legacyStudents)/$(studentId))
            && get(/databases/$(database)/documents/$(legacyStudents)/$(studentId)).data.classId == classId
          )
        );
    }

    function assignedToClass(schoolId, classId) {
      let legacyClasses = 'classes_' + schoolId;
      return (
          nestedClassExists(schoolId, classId)
          && classAssignedToCurrentUser(
            get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)).data
          )
        ) || (
          legacyClassExists(schoolId, classId)
          && classAssignedToCurrentUser(
            get(/databases/$(database)/documents/$(legacyClasses)/$(classId)).data
          )
        );
    }

    function teachesClass(schoolId, classId) {
      let legacyClasses = 'classes_' + schoolId;
      return (
          nestedClassExists(schoolId, classId)
          && classTaughtByCurrentUser(
            get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)).data
          )
        ) || (
          legacyClassExists(schoolId, classId)
          && classTaughtByCurrentUser(
            get(/databases/$(database)/documents/$(legacyClasses)/$(classId)).data
          )
        );
    }

    function assignedThroughLegacyClassName(schoolId, data) {
      let nestedSettings = /databases/$(database)/documents/schools/$(schoolId)/settings/class_permissions;
      let legacySettingsCollection = 'settings_' + schoolId;
      let legacySettings = /databases/$(database)/documents/$(legacySettingsCollection)/class_permissions;
      return 'className' in data && data.className is string && (
        (
          exists(nestedSettings)
          && get(nestedSettings).data.classes is map
          && data.className in get(nestedSettings).data.classes
          && get(nestedSettings).data.classes[data.className].teacherIds is list
          && request.auth.uid in get(nestedSettings).data.classes[data.className].teacherIds
        ) || (
          exists(legacySettings)
          && get(legacySettings).data.classes is map
          && data.className in get(legacySettings).data.classes
          && get(legacySettings).data.classes[data.className].teacherIds is list
          && request.auth.uid in get(legacySettings).data.classes[data.className].teacherIds
        )
      );
    }

    function canViewStudent(schoolId, data) {
      return hasStudentDataAccess(schoolId) && (
        (
          'classId' in data
          && classRolePermission(schoolId, 'students.view', data.classId)
        )
        || (
          'classId' in data
          && data.classId is string
          && assignedToClass(schoolId, data.classId)
        )
        || (request.auth.token.keys().hasAny(['global_admin']) && request.auth.token.global_admin == true)
        || currentUser().role == 'principal'
        || hasSchoolWideStudentReadPermission()
        || hasAnyRolePermission(schoolId, [
          'students.view', 'students.update', 'students.archive', 'students.transferClass',
          'students.promote', 'students.markGraduate', 'students.markWithdrawn',
          'students.markDropout', 'students.restore'
        ])
        || assignedThroughLegacyClassName(schoolId, data)
      );
    }

    function personalFileStudentData(schoolId, studentId) {
      let legacyStudents = 'students_' + schoolId;
      return exists(/databases/$(database)/documents/$(legacyStudents)/$(studentId))
        ? get(/databases/$(database)/documents/$(legacyStudents)/$(studentId)).data
        : get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data;
    }

    function canViewPersonalFile(schoolId, studentId) {
      let studentData = personalFileStudentData(schoolId, studentId);
      return hasStudentDataAccess(schoolId) && (
        currentUser().role == 'principal'
        || studentPermission('personalFile.view')
        || studentPermission('personalFile.manage')
        || rolePermission(schoolId, 'personalFile.view')
        || rolePermission(schoolId, 'personalFile.manage')
        || (
          studentData.classId is string
          && (
            classRolePermission(schoolId, 'personalFile.view', studentData.classId)
            || classRolePermission(schoolId, 'personalFile.manage', studentData.classId)
          )
        )
      );
    }

    function canViewCv(schoolId, studentId) {
      let studentData = personalFileStudentData(schoolId, studentId);
      return hasStudentDataAccess(schoolId) && (
        currentUser().role == 'principal'
        || studentPermission('cv.view')
        || studentPermission('cv.create')
        || studentPermission('cv.edit')
        || rolePermission(schoolId, 'cv.view')
        || rolePermission(schoolId, 'cv.create')
        || rolePermission(schoolId, 'cv.edit')
        || (
          studentData.classId is string
          && (
            classRolePermission(schoolId, 'cv.view', studentData.classId)
            || classRolePermission(schoolId, 'cv.create', studentData.classId)
            || classRolePermission(schoolId, 'cv.edit', studentData.classId)
          )
        )
      );
    }

    function canViewCvTemplates(schoolId) {
      return hasStudentDataAccess(schoolId) && (
        currentUser().role == 'principal'
        || studentPermission('cvTemplates.view')
        || studentPermission('cvTemplates.create')
        || studentPermission('cvTemplates.update')
        || rolePermission(schoolId, 'cvTemplates.view')
        || rolePermission(schoolId, 'cvTemplates.create')
        || rolePermission(schoolId, 'cvTemplates.update')
      );
    }

    function canReadCvTemplate(schoolId, data) {
      return data.schoolId == schoolId
        && data.status == 'active'
        && canViewCvTemplates(schoolId)
        && (data.scope == 'school' || data.createdBy == request.auth.uid);
    }

    function validPersonalFileCreate(collectionName, studentId, data) {
      let studentsCollection = 'students_' + data.schoolId;
      return data.schoolId is string
        && collectionName == 'personal_files_' + data.schoolId
        && data.studentId == studentId
        && data.status == 'active'
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid
        && existsAfter(/databases/$(database)/documents/$(studentsCollection)/$(studentId))
        && getAfter(/databases/$(database)/documents/$(studentsCollection)/$(studentId)).data.schoolId == data.schoolId
        && getAfter(/databases/$(database)/documents/$(studentsCollection)/$(studentId)).data.createdBy == request.auth.uid;
    }

    function canViewSkillCatalog(schoolId) {
      return hasStudentDataAccess(schoolId) && (
        currentUser().role == 'principal'
        || studentPermission('personalFile.view')
        || studentPermission('personalFile.manage')
        || studentPermission('cv.manageSkills')
        || rolePermission(schoolId, 'personalFile.view')
        || rolePermission(schoolId, 'personalFile.manage')
        || rolePermission(schoolId, 'cv.manageSkills')
      );
    }

    function isAttendanceFile(data) {
      return data.fileType is string && data.fileType == 'attendance';
    }

    function canViewAttendance(schoolId, data) {
      return hasStudentDataAccess(schoolId)
        && isAttendanceFile(data)
        && data.schoolId == schoolId
        && data.classId is string
        && classExists(schoolId, data.classId)
        && (
          (request.auth.token.keys().hasAny(['global_admin']) && request.auth.token.global_admin == true)
          || currentUser().role == 'principal'
          || studentPermission('attendance_view')
          || studentPermission('attendance_edit')
          || studentPermission('attendance_create')
          || studentPermission('attendance_manage_legend')
          || studentPermission('attendance_manage_dates')
          || assignedToClass(schoolId, data.classId)
        );
    }

    function canCreateAttendance(schoolId, data) {
      return hasStudentDataAccess(schoolId)
        && data.classId is string
        && classExists(schoolId, data.classId)
        && (
          currentUser().role == 'principal'
          || studentPermission('attendance_create')
          || teachesClass(schoolId, data.classId)
        );
    }

    function canEditAttendance(schoolId, data) {
      return canViewAttendance(schoolId, data) && (
        currentUser().role == 'principal'
        || studentPermission('attendance_edit')
        || teachesClass(schoolId, data.classId)
      );
    }

    function canInitializeAttendance(schoolId, data) {
      return isAttendanceFile(data)
        && data.schoolId == schoolId
        && data.setupStatus == 'creating'
        && data.createdBy == request.auth.uid
        && canCreateAttendance(schoolId, data);
    }

    function canManageAttendanceLegend(schoolId, data) {
      return canViewAttendance(schoolId, data) && (
        currentUser().role == 'principal'
        || studentPermission('attendance_manage_legend')
      );
    }

    function validAttendanceFileCreate(schoolId, data) {
      return data.keys().hasAll([
          'name', 'fileType', 'folderId', 'schoolId', 'classId', 'className',
          'dateRange', 'timezone', 'status', 'setupStatus', 'createdBy', 'updatedBy'
        ])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 140
        && data.folderId is string
        && data.schoolId == schoolId
        && data.status == 'active'
        && data.setupStatus == 'creating'
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid
        && canCreateAttendance(schoolId, data);
    }

    function safeAttendanceFileUpdate(schoolId) {
      return (
          (
            canInitializeAttendance(schoolId, resource.data)
            && request.resource.data.setupStatus in ['ready', 'error']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'setupStatus', 'studentCount', 'scheduledDayCount', 'updatedBy', 'updatedAt'
            ])
          )
          || canEditAttendance(schoolId, resource.data)
        )
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.fileType == resource.data.fileType
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'description', 'folderId', 'setupStatus', 'status', 'studentCount',
          'scheduledDayCount', 'updatedBy', 'updatedAt', 'pinnedBy'
        ])
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinnedBy'])
          || request.resource.data.updatedBy == request.auth.uid
        );
    }

    function validAttendanceChildBase(schoolId, fileId, data) {
      return data.schoolId == schoolId && data.fileId == fileId;
    }

    function validAttendanceRecordWrite(schoolId, fileId, fileData, data) {
      return canEditAttendance(schoolId, fileData)
        && validAttendanceChildBase(schoolId, fileId, data)
        && data.classId == fileData.classId
        && data.studentId is string
        && data.dateKey is string
        && data.primaryStatusId is string
        && data.actionIds is list
        && data.note is string
        && data.note.size() <= 2000
        && data.updatedBy == request.auth.uid;
    }

    function nestedAttendanceFileData(schoolId, fileId) {
      return get(/databases/$(database)/documents/schools/$(schoolId)/files/$(fileId)).data;
    }

    function canCreateStudent(schoolId, data) {
      return hasStudentDataAccess(schoolId)
        && data.classId is string
        && classExists(schoolId, data.classId)
        && (
          teachesClass(schoolId, data.classId)
          || currentUser().role == 'principal'
          || studentPermission('students_create')
          || studentPermission('students_edit')
          || rolePermission(schoolId, 'students.create')
          || classRolePermission(schoolId, 'students.create', data.classId)
        );
    }

    function canUpdateStudentBase(schoolId, data) {
      return hasStudentDataAccess(schoolId) && (
        (
          'classId' in data
          && data.classId is string
          && (
            teachesClass(schoolId, data.classId)
            || classRolePermission(schoolId, 'students.update', data.classId)
            || classRolePermission(schoolId, 'students.create', data.classId)
          )
        )
        || currentUser().role == 'principal'
        || studentPermission('students_update')
        || studentPermission('students_edit')
        || rolePermission(schoolId, 'students.update')
      );
    }

    function canManageAcademicYears(schoolId) {
      return hasStudentDataAccess(schoolId) && (
        currentUser().role == 'principal'
        || studentPermission('academicYears.manage')
        || rolePermission(schoolId, 'academicYears.manage')
      );
    }

    function canPromoteStudents(schoolId) {
      return hasStudentDataAccess(schoolId) && (
        currentUser().role == 'principal'
        || studentPermission('students.promote')
        || studentPermission('classes.promote')
        || rolePermission(schoolId, 'students.promote')
        || rolePermission(schoolId, 'classes.promote')
      );
    }

    function canSetEnrollmentStatus(schoolId, status) {
      return hasStudentDataAccess(schoolId) && (
        currentUser().role == 'principal'
        || (status == 'graduated' && studentPermission('students.markGraduate'))
        || (status == 'withdrawn' && studentPermission('students.markWithdrawn'))
        || (status == 'dropout' && studentPermission('students.markDropout'))
        || (status == 'transferred' && studentPermission('students.markWithdrawn'))
        || (status == 'active' && studentPermission('students.restore'))
        || (status == 'graduated' && rolePermission(schoolId, 'students.markGraduate'))
        || (status == 'withdrawn' && rolePermission(schoolId, 'students.markWithdrawn'))
        || (status == 'dropout' && rolePermission(schoolId, 'students.markDropout'))
        || (status == 'transferred' && rolePermission(schoolId, 'students.markWithdrawn'))
        || (status == 'active' && rolePermission(schoolId, 'students.restore'))
        || (status == 'completed' && canPromoteStudents(schoolId))
      );
    }

    function canViewEnrollment(schoolId, data) {
      return data.schoolId == schoolId
        && data.classId is string
        && (
          canViewAllStudents(schoolId)
          || assignedToClass(schoolId, data.classId)
        );
    }

    function validAcademicYearCreate(schoolId, data) {
      return canManageAcademicYears(schoolId)
        && data.keys().hasAll([
          'schoolId', 'label', 'startYear', 'endYear', 'status',
          'createdBy', 'updatedBy', 'createdAt', 'updatedAt'
        ])
        && data.schoolId == schoolId
        && data.label is string
        && data.label.size() > 0
        && data.label.size() <= 30
        && data.startYear is int
        && data.endYear == data.startYear + 1
        && data.startYear >= 2025
        && data.startYear <= 2200
        && data.status in ['active', 'closed', 'archived']
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid;
    }

    function safeAcademicYearUpdate(schoolId) {
      return canManageAcademicYears(schoolId)
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.startYear == resource.data.startYear
        && request.resource.data.endYear == resource.data.endYear
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 30
        && request.resource.data.status in ['active', 'closed', 'archived']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'label', 'status', 'updatedBy', 'updatedAt'
        ]);
    }

    function validAcademicYearSettings(schoolId, data) {
      return canManageAcademicYears(schoolId)
        && data.schoolId == schoolId
        && data.activeAcademicYearId is string
        && data.activeAcademicYearId.size() > 0
        && data.updatedBy == request.auth.uid
        && !data.keys().hasAny(['role', 'permissions', 'schoolIds']);
    }

    function validEnrollmentBase(schoolId, data) {
      return hasStudentDataAccess(schoolId)
        && data.keys().hasAll([
          'studentId', 'schoolId', 'academicYearId', 'classId', 'enrollmentStatus',
          'createdBy', 'updatedBy', 'createdAt', 'updatedAt'
        ])
        && data.schoolId == schoolId
        && data.studentId is string
        && data.studentId.size() > 0
        && data.academicYearId is string
        && data.academicYearId.size() > 0
        && data.classId is string
        && classExists(schoolId, data.classId)
        && data.enrollmentStatus in [
          'active', 'completed', 'graduated', 'withdrawn', 'dropout', 'transferred'
        ];
    }

    function validEnrollmentCreate(schoolId, enrollmentId, data) {
      return validEnrollmentBase(schoolId, data)
        && enrollmentId == data.studentId + '__' + data.academicYearId
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid
        && (
          (
            data.enrollmentStatus == 'active'
            && (
              canPromoteStudents(schoolId)
              || canCreateStudent(schoolId, data)
              || studentPermission('students.restore')
              || rolePermission(schoolId, 'students.restore')
              || classRolePermission(schoolId, 'students.create', data.classId)
            )
          )
          || canSetEnrollmentStatus(schoolId, data.enrollmentStatus)
        );
    }

    // Promotion touches four documents atomically. Keep the exact-permission path
    // compact enough for the Rules runtime's per-request expression budget.
    function directPromotionPermission(schoolId) {
      return hasStudentDataAccess(schoolId)
        && studentPermission('students.promote');
    }

    function validDirectPromotionEnrollmentCreate(schoolId, enrollmentId, data) {
      return directPromotionPermission(schoolId)
        && data.schoolId == schoolId
        && data.studentId is string
        && data.academicYearId is string
        && data.classId is string
        && data.enrollmentStatus == 'active'
        && enrollmentId == data.studentId + '__' + data.academicYearId
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid
        && classExists(schoolId, data.classId);
    }

    function validDirectTeacherStudentCreate(schoolId, data) {
      return hasStudentDataAccess(schoolId)
        && data.schoolId == schoolId
        && data.classId is string
        && teachesClass(schoolId, data.classId)
        && data.fullName is string
        && data.fullName.size() > 0
        && data.status == 'active'
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid;
    }

    function validDirectTeacherEnrollmentCreate(schoolId, enrollmentId, data) {
      return hasStudentDataAccess(schoolId)
        && data.schoolId == schoolId
        && data.studentId is string
        && data.academicYearId is string
        && data.classId is string
        && teachesClass(schoolId, data.classId)
        && data.enrollmentStatus == 'active'
        && enrollmentId == data.studentId + '__' + data.academicYearId
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid;
    }

    function directLifecyclePermission(schoolId, status) {
      return hasStudentDataAccess(schoolId) && (
        (status == 'graduated' && studentPermission('students.markGraduate'))
        || (status == 'withdrawn' && studentPermission('students.markWithdrawn'))
        || (status == 'transferred' && studentPermission('students.markWithdrawn'))
        || (status == 'dropout' && studentPermission('students.markDropout'))
        || (status == 'active' && studentPermission('students.restore'))
      );
    }

    function safeDirectLifecycleEnrollmentUpdate(schoolId, enrollmentId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return directLifecyclePermission(schoolId, request.resource.data.enrollmentStatus)
        && resource.data.schoolId == schoolId
        && enrollmentId == resource.data.studentId + '__' + resource.data.academicYearId
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.academicYearId == resource.data.academicYearId
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid
        && changed.hasOnly([
          'enrollmentStatus', 'endDate', 'exitReason', 'exitNote',
          'graduationYear', 'updatedBy', 'updatedAt'
        ]);
    }

    function safeDirectPromotionEnrollmentUpdate(schoolId, enrollmentId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return directPromotionPermission(schoolId)
        && resource.data.schoolId == schoolId
        && enrollmentId == resource.data.studentId + '__' + resource.data.academicYearId
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.academicYearId == resource.data.academicYearId
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.enrollmentStatus == 'completed'
        && request.resource.data.updatedBy == request.auth.uid
        && changed.hasOnly(['enrollmentStatus', 'endDate', 'updatedBy', 'updatedAt']);
    }

    function safeEnrollmentUpdate(schoolId, enrollmentId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return validEnrollmentBase(schoolId, request.resource.data)
        && enrollmentId == resource.data.studentId + '__' + resource.data.academicYearId
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.academicYearId == resource.data.academicYearId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid
        && changed.hasOnly([
          'classId', 'className', 'grade', 'majorIds', 'studyProgramIds',
          'enrollmentStatus', 'startDate', 'endDate', 'exitReason', 'exitNote',
          'graduationYear', 'displayName', 'updatedBy', 'updatedAt'
        ])
        && (
          (
            changed.hasAny(['classId', 'className', 'grade'])
            && (
              currentUser().role == 'principal'
              || studentPermission('students.transferClass')
              || studentPermission('students_transfer_class')
              || rolePermission(schoolId, 'students.transferClass')
              || classRolePermission(schoolId, 'students.transferClass', resource.data.classId)
            )
          )
          || (
            changed.hasAny(['enrollmentStatus', 'endDate', 'exitReason', 'exitNote', 'graduationYear'])
            && (
              (
                request.resource.data.enrollmentStatus == 'completed'
                && canPromoteStudents(schoolId)
              )
              || canSetEnrollmentStatus(schoolId, request.resource.data.enrollmentStatus)
            )
          )
          || (
            !changed.hasAny(['classId', 'className', 'grade', 'enrollmentStatus', 'endDate', 'exitReason', 'exitNote', 'graduationYear'])
            && canUpdateStudentBase(schoolId, resource.data)
          )
        );
    }

    function hasNoPasswordFields(data) {
      return !data.keys().hasAny(['_authPassword', '_pendingPassword', 'password', 'passwordHash']);
    }

    function safeSelfProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'fullName',
        'phone',
        'jobTitle',
        'avatar',
        'avatarStyle',
        'dashboardPreferences',
        'isOnline',
        'lastSeen'
      ]) && hasNoPasswordFields(request.resource.data);
    }

    function userBelongsToSchool(userData, schoolId) {
      return (userData.schoolId is string && userData.schoolId == schoolId)
        || (userData.schoolIds is list && schoolId in userData.schoolIds);
    }

    function sharesSchool(userData) {
      return activeUser() && (
        (userData.schoolId is string && isSchoolMember(userData.schoolId))
        || (
          userData.schoolIds is list
          && currentUser().schoolIds is list
          && userData.schoolIds.hasAny(currentUser().schoolIds)
        )
        || (
          userData.schoolIds is list
          && currentUser().schoolId is string
          && currentUser().schoolId in userData.schoolIds
        )
      );
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && request.auth.uid in get(
          /databases/$(database)/documents/conversations/$(conversationId)
        ).data.participants;
    }

    function validConversationCreate(data) {
      return activeUser()
        && data.participants is list
        && data.participants.size() == 2
        && request.auth.uid in data.participants
        && data.schoolId is string
        && isSchoolMember(data.schoolId)
        && exists(/databases/$(database)/documents/users/$(data.participants[0]))
        && exists(/databases/$(database)/documents/users/$(data.participants[1]))
        && userBelongsToSchool(
          get(/databases/$(database)/documents/users/$(data.participants[0])).data,
          data.schoolId
        )
        && userBelongsToSchool(
          get(/databases/$(database)/documents/users/$(data.participants[1])).data,
          data.schoolId
        );
    }

    function isPersonalTask(data) {
      return 'scope' in data && data.scope == 'personal';
    }

    function isAssignedTask(data) {
      return ('scope' in data && data.scope == 'assigned')
        || (
          !('scope' in data)
          && 'assigneeType' in data
          && data.assigneeType == 'individual'
        );
    }

    function isOrganizationTask(data) {
      return !isPersonalTask(data);
    }

    function taskVisibleToCurrentUser(schoolId, data) {
      return isOrganizationTask(data) && (
        hasPermission(schoolId, 'tasks_edit')
        || (
          isSchoolMember(schoolId)
          && (
            ('createdBy' in data && data.createdBy is string && data.createdBy == request.auth.uid)
            || !('assigneeType' in data)
            || data.assigneeType == 'all_school'
            || (data.assigneeIds is list && request.auth.uid in data.assigneeIds)
            || (
              data.assigneeType == 'team'
              && currentUser().teamIds is list
              && data.assigneeTeamId in currentUser().teamIds
            )
          )
        )
      );
    }

    function validAssignedTaskTarget(schoolId, data) {
      return data.assigneeIds is list
        && data.assigneeIds.size() == 1
        && exists(/databases/$(database)/documents/users/$(data.assigneeIds[0]))
        && userBelongsToSchool(
          get(/databases/$(database)/documents/users/$(data.assigneeIds[0])).data,
          schoolId
        );
    }

    function validOrganizationTaskCreate(schoolId, data) {
      return isSchoolMember(schoolId)
        && data.keys().hasAll(['scope', 'schoolId', 'createdBy', 'title', 'status'])
        && data.schoolId == schoolId
        && data.createdBy == request.auth.uid
        && data.title is string
        && data.title.size() > 0
        && (
          (
            data.scope == 'assigned'
            && data.assigneeType == 'individual'
            && hasPermission(schoolId, 'tasks_assign')
            && validAssignedTaskTarget(schoolId, data)
          )
          || (
            data.scope == 'team'
            && data.assigneeType == 'team'
            && data.teamId is string
            && data.teamId.size() > 0
            && data.assigneeTeamId == data.teamId
            && hasPermission(schoolId, 'tasks_edit')
          )
        );
    }

    function safeOrganizationTaskUpdate(schoolId) {
      return isOrganizationTask(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'schoolId', 'createdBy', 'ownerId'
        ]) == false
        && (
          hasPermission(schoolId, 'tasks_edit')
          || (
            isAssignedTask(resource.data)
            && resource.data.assigneeIds is list
            && request.auth.uid in resource.data.assigneeIds
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'completedAt', 'updatedAt'
            ])
          )
        );
    }

    function validPersonalTaskCreate(userId, data) {
      return activeUser()
        && request.auth.uid == userId
        && data.keys().hasAll(['scope', 'schoolId', 'ownerId', 'createdBy', 'title', 'status'])
        && data.scope == 'personal'
        && data.ownerId == request.auth.uid
        && data.createdBy == request.auth.uid
        && data.schoolId is string
        && isSchoolMember(data.schoolId)
        && data.title is string
        && data.title.size() > 0
        && data.assigneeIds is list
        && data.assigneeIds.size() == 0
        && data.teamId == ''
        && data.assigneeTeamId == '';
    }

    function personalTaskOwner(userId, data) {
      return activeUser()
        && request.auth.uid == userId
        && data.scope == 'personal'
        && data.ownerId == request.auth.uid
        && data.createdBy == request.auth.uid
        && data.schoolId is string
        && isSchoolMember(data.schoolId);
    }

    function safePersonalTaskUpdate(userId) {
      return personalTaskOwner(userId, resource.data)
        && personalTaskOwner(userId, request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title', 'description', 'priority', 'status', 'dueDate', 'reminderAt',
          'completedAt', 'updatedAt', 'tags', 'attachedFileId', 'attachedFileName',
          'pinnedBy', 'sourceTaskId'
        ]);
    }

    function validClassCreate(schoolId, data) {
      return hasStudentDataAccess(schoolId)
        && (
          currentUser().role == 'principal'
          || studentPermission('classes_create')
          || studentPermission('classes.create')
          || rolePermission(schoolId, 'classes.create')
        )
        && data.keys().hasAll([
          'name', 'normalizedName', 'academicYear', 'schoolId', 'teacherId',
          'staffIds', 'status', 'createdBy', 'updatedBy'
        ])
        && data.schoolId == schoolId
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid
        && data.name is string
        && data.name.size() > 0
        && data.academicYear is string
        && data.academicYear.size() > 0
        && (!('academicYearId' in data) || data.academicYearId is string)
        && data.status in ['active', 'archived']
        && (
          data.teacherId == ''
          || currentUser().role == 'principal'
          || studentPermission('classes_assign_teacher')
          || studentPermission('classes.assignTeacher')
        )
        && (
          data.status == 'active'
          || currentUser().role == 'principal'
          || studentPermission('classes_archive')
          || studentPermission('classes.archive')
        );
    }

    function safeClassUpdate(schoolId, classId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return hasStudentDataAccess(schoolId)
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && (!('academicYearId' in resource.data) || request.resource.data.academicYearId == resource.data.academicYearId)
        && request.resource.data.updatedBy == request.auth.uid
        && (
          currentUser().role == 'principal'
          || rolePermission(schoolId, 'classes.update')
          || classRolePermission(schoolId, 'classes.update', classId)
          || (
            (studentPermission('classes_update') || studentPermission('classes.update'))
            && (
              !changed.hasAny(['teacherId'])
              || studentPermission('classes_assign_teacher')
              || studentPermission('classes.assignTeacher')
            )
            && (
              !changed.hasAny(['status'])
              || studentPermission('classes_archive')
              || studentPermission('classes.archive')
            )
          )
          || (
            (studentPermission('classes_assign_teacher') || studentPermission('classes.assignTeacher'))
            && changed.hasOnly(['teacherId', 'updatedBy', 'updatedAt'])
          )
          || (
            (studentPermission('classes_archive') || studentPermission('classes.archive'))
            && changed.hasOnly(['status', 'updatedBy', 'updatedAt'])
          )
        );
    }

    function validStudentCreate(schoolId, data) {
      return canCreateStudent(schoolId, data)
        && data.keys().hasAll([
          'fullName', 'schoolId', 'classId', 'status', 'createdBy', 'updatedBy'
        ])
        && data.schoolId == schoolId
        && data.createdBy == request.auth.uid
        && data.updatedBy == request.auth.uid
        && data.fullName is string
        && data.fullName.size() > 0
        && data.status in ['active', 'transferred', 'graduated', 'withdrawn', 'dropout', 'archived']
        && (
          data.status == 'active'
          || currentUser().role == 'principal'
          || studentPermission('students_archive')
        )
        && (
          (
            data.trackIds is list
            && data.trackIds.size() == 0
            && data.programTypes is list
            && data.programTypes.size() == 0
          )
          || canManagePrograms(schoolId)
        );
    }

    function safeStudentUpdate(schoolId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return hasStudentDataAccess(schoolId)
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.status in ['active', 'transferred', 'graduated', 'withdrawn', 'dropout', 'archived']
        && (
          changed.hasAny(['classId', 'className', 'gradeLevel', 'academicYear', 'joinedAt'])
          ? (
              (
                canPromoteStudents(schoolId)
                || currentUser().role == 'principal'
                || studentPermission('students_transfer_class')
                || studentPermission('students.transferClass')
              )
              && changed.hasOnly([
                'classId', 'className', 'gradeLevel', 'academicYear', 'joinedAt',
                'currentEnrollmentId', 'status', 'endDate', 'updatedBy', 'updatedAt'
              ])
              && classExists(schoolId, request.resource.data.classId)
            )
          : changed.hasAny(['status', 'endDate'])
          ? (
              (
                currentUser().role == 'principal'
                || studentPermission('students_archive')
                || studentPermission('students.archive')
                || canSetEnrollmentStatus(schoolId, request.resource.data.status)
              )
              && changed.hasOnly(['status', 'endDate', 'updatedBy', 'updatedAt'])
            )
          : changed.hasAny(['trackId', 'trackIds', 'programType', 'programTypes'])
          ? (
              canManagePrograms(schoolId)
              && (
                canUpdateStudentBase(schoolId, resource.data)
                || changed.hasOnly([
                  'trackId', 'trackIds', 'programType', 'programTypes', 'updatedBy', 'updatedAt'
                ])
              )
            )
          : canUpdateStudentBase(schoolId, resource.data)
        );
    }

    function safeDirectPromotionStudentUpdate(schoolId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return directPromotionPermission(schoolId)
        && resource.data.schoolId == schoolId
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.classId is string
        && classExists(schoolId, request.resource.data.classId)
        && changed.hasOnly([
          'classId', 'className', 'gradeLevel', 'academicYear', 'joinedAt',
          'currentEnrollmentId', 'status', 'endDate', 'updatedBy', 'updatedAt'
        ]);
    }

    function safeDirectLifecycleStudentUpdate(schoolId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return directLifecyclePermission(schoolId, request.resource.data.status)
        && resource.data.schoolId == schoolId
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.updatedBy == request.auth.uid
        && changed.hasOnly(['status', 'endDate', 'updatedBy', 'updatedAt']);
    }

    function safeDirectScopedRoleStudentUpdate(schoolId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return hasStudentDataAccess(schoolId)
        && resource.data.schoolId == schoolId
        && resource.data.classId is string
        && classRolePermission(schoolId, 'students.update', resource.data.classId)
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status == resource.data.status
        && request.resource.data.updatedBy == request.auth.uid
        && changed.hasOnly([
          'firstName', 'lastName', 'fullName', 'idNumber', 'phone', 'parentPhone',
          'additionalSubjects', 'updatedBy', 'updatedAt'
        ]);
    }

    function validStudentHistoryCreate(schoolId, studentId, studentData, data) {
      return hasStudentDataAccess(schoolId)
        && data.schoolId == schoolId
        && data.studentId == studentId
        && data.createdBy == request.auth.uid
        && (
          canPromoteStudents(schoolId)
          || currentUser().role == 'principal'
          || canUpdateStudentBase(schoolId, studentData)
          || studentPermission('students_create')
          || studentPermission('students_update')
          || studentPermission('students_transfer_class')
          || studentPermission('students_archive')
          || studentPermission('students_edit')
          || studentPermission('students.promote')
          || studentPermission('classes.promote')
          || studentPermission('students.markGraduate')
          || studentPermission('students.markWithdrawn')
          || studentPermission('students.markDropout')
          || studentPermission('students.restore')
        );
    }

    function validDirectPromotionHistoryCreate(schoolId, studentId, data) {
      return directPromotionPermission(schoolId)
        && data.schoolId == schoolId
        && data.studentId == studentId
        && data.type == 'student_promoted'
        && data.previousClassId is string
        && data.previousAcademicYearId is string
        && data.nextClassId is string
        && data.nextAcademicYearId is string
        && data.effectiveDate is string
        && data.createdBy == request.auth.uid;
    }

    function validDirectTeacherHistoryCreate(schoolId, studentId, data) {
      return hasStudentDataAccess(schoolId)
        && data.schoolId == schoolId
        && data.studentId == studentId
        && data.type == 'student_created'
        && data.nextClassId is string
        && teachesClass(schoolId, data.nextClassId)
        && data.effectiveDate is string
        && data.createdBy == request.auth.uid;
    }

    function validDirectLifecycleHistoryCreate(schoolId, studentId, data) {
      return data.schoolId == schoolId
        && data.studentId == studentId
        && data.effectiveDate is string
        && data.createdBy == request.auth.uid
        && (
          (data.type == 'student_graduated' && directLifecyclePermission(schoolId, 'graduated'))
          || (data.type == 'student_withdrawn' && directLifecyclePermission(schoolId, 'withdrawn'))
          || (data.type == 'student_transferred_out' && directLifecyclePermission(schoolId, 'transferred'))
          || (data.type == 'student_dropout' && directLifecyclePermission(schoolId, 'dropout'))
          || (data.type == 'student_restored' && directLifecyclePermission(schoolId, 'active'))
        );
    }

    function canReadStudentNote(schoolId, studentData, noteData) {
      return canViewStudent(schoolId, studentData)
        && (
          currentUser().role == 'principal'
          || studentPermission('students_view_notes')
          || studentPermission('students.viewSensitiveNotes')
          || rolePermission(schoolId, 'students.viewSensitiveNotes')
          || classRolePermission(schoolId, 'students.viewSensitiveNotes', studentData.classId)
        )
        && (
          noteData.visibility != 'school_admin'
          || currentUser().role == 'principal'
          || studentPermission('students.viewSensitiveNotes')
          || rolePermission(schoolId, 'students.viewSensitiveNotes')
          || classRolePermission(schoolId, 'students.viewSensitiveNotes', studentData.classId)
        );
    }

    function canAddStudentNote(schoolId, studentData) {
      return currentUser().role == 'principal'
        || studentPermission('students_add_notes')
        || studentPermission('students.addNotes')
        || rolePermission(schoolId, 'students.addNotes')
        || classRolePermission(schoolId, 'students.addNotes', studentData.classId);
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isGlobalAdmin()
        || sharesSchool(resource.data)
      );
      allow create: if false;
      allow update: if signedIn()
        && request.auth.uid == userId
        && safeSelfProfileUpdate();
      allow delete: if false;

      match /personalTasks/{taskId} {
        allow read: if personalTaskOwner(userId, resource.data);
        allow create: if validPersonalTaskCreate(userId, request.resource.data);
        allow update: if safePersonalTaskUpdate(userId);
        allow delete: if personalTaskOwner(userId, resource.data);
      }
    }

    match /schools/{schoolId} {
      allow read: if isSchoolMember(schoolId);
      allow create, update, delete: if false;

      match /tasks/{taskId} {
        allow read: if taskVisibleToCurrentUser(schoolId, resource.data);
        allow create: if validOrganizationTaskCreate(schoolId, request.resource.data);
        allow update: if safeOrganizationTaskUpdate(schoolId);
        allow delete: if isOrganizationTask(resource.data)
          && hasPermission(schoolId, 'tasks_edit');

        match /chat/{messageId} {
          allow read: if taskVisibleToCurrentUser(
            schoolId,
            get(/databases/$(database)/documents/schools/$(schoolId)/tasks/$(taskId)).data
          );
          allow create: if taskVisibleToCurrentUser(
              schoolId,
              get(/databases/$(database)/documents/schools/$(schoolId)/tasks/$(taskId)).data
            )
            && request.resource.data.authorId == request.auth.uid;
          allow update: if false;
          allow delete: if request.auth.uid == resource.data.authorId || canManageSchoolUsers(schoolId);
        }
      }

      match /academicYears/{academicYearId} {
        allow read: if hasStudentDataAccess(schoolId) && isSchoolMember(schoolId);
        allow create: if validAcademicYearCreate(schoolId, request.resource.data);
        allow update: if safeAcademicYearUpdate(schoolId);
        allow delete: if false;
      }

      match /studentEnrollments/{enrollmentId} {
        allow read: if canViewEnrollment(schoolId, resource.data);
        allow create: if validEnrollmentCreate(
          schoolId,
          enrollmentId,
          request.resource.data
        );
        allow update: if safeEnrollmentUpdate(schoolId, enrollmentId);
        allow delete: if false;
      }

      match /classes/{classId} {
        allow read: if classRolePermission(schoolId, 'classes.view', classId)
          || classRolePermission(schoolId, 'students.view', classId)
          || canViewClass(schoolId, resource.data);
        allow create: if validClassCreate(schoolId, request.resource.data);
        allow update: if safeClassUpdate(schoolId, classId);
        allow delete: if false;

        match /history/{historyId} {
          allow read: if canViewClass(
            schoolId,
            get(/databases/$(database)/documents/schools/$(schoolId)/classes/$(classId)).data
          );
          allow create: if request.resource.data.schoolId == schoolId
            && request.resource.data.classId == classId
            && request.resource.data.createdBy == request.auth.uid
            && hasStudentDataAccess(schoolId)
            && (
              currentUser().role == 'principal'
              || studentPermission('classes_update')
              || studentPermission('classes_archive')
              || studentPermission('classes_assign_teacher')
            );
          allow update, delete: if false;
        }
      }

      match /students/{studentId} {
        allow read: if canViewStudent(schoolId, resource.data);
        allow create: if validStudentCreate(schoolId, request.resource.data);
        allow update: if safeStudentUpdate(schoolId);
        allow delete: if false;

        match /history/{historyId} {
          allow read: if canViewStudent(
            schoolId,
            get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data
          );
          allow create: if validStudentHistoryCreate(
            schoolId,
            studentId,
            getAfter(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data,
            request.resource.data
          );
          allow update, delete: if false;
        }

        match /notes/{noteId} {
          allow read: if canReadStudentNote(
            schoolId,
            get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data,
            resource.data
          );
          allow create: if canViewStudent(
              schoolId,
              get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data
            )
            && canAddStudentNote(
              schoolId,
              get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data
            )
            && request.resource.data.schoolId == schoolId
            && request.resource.data.studentId == studentId
            && request.resource.data.createdBy == request.auth.uid
            && request.resource.data.content is string
            && request.resource.data.content.size() > 0
            && request.resource.data.visibility in ['class_staff', 'school_admin'];
          allow update, delete: if false;
        }
      }

      match /personalFiles/{studentId} {
        allow read: if canViewPersonalFile(schoolId, studentId);
        allow create: if request.resource.data.schoolId == schoolId
          && request.resource.data.studentId == studentId
          && request.resource.data.status == 'active'
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedBy == request.auth.uid
          && existsAfter(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId))
          && getAfter(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId)).data.createdBy == request.auth.uid;
        allow update, delete: if false;

        match /{kind}/{itemId} {
          allow read: if kind in [
            'documents', 'credentials', 'experiences', 'skills', 'recommendations'
          ] && canViewPersonalFile(schoolId, studentId);
          allow create, update, delete: if false;
        }

        match /cvDocuments/{documentId} {
          allow read: if canViewCv(schoolId, studentId);
          allow create, update, delete: if false;

          match /versions/{versionId} {
            allow read: if canViewCv(schoolId, studentId);
            allow create, update, delete: if false;

            match /exports/{exportId} {
              allow read: if canViewCv(schoolId, studentId);
              allow create, update, delete: if false;
            }
          }
        }
      }

      match /skillCatalog/{skillId} {
        allow read: if canViewSkillCatalog(schoolId);
        allow create, update, delete: if false;
      }

      match /cvTemplates/{templateId} {
        allow read: if canReadCvTemplate(schoolId, resource.data);
        allow create, update, delete: if false;
      }

      match /files/{fileId} {
        allow read: if canViewSchoolResource(schoolId);
        allow create: if (
            isAttendanceFile(request.resource.data)
            && validAttendanceFileCreate(schoolId, request.resource.data)
          ) || (
            !isAttendanceFile(request.resource.data)
            && hasPermission(schoolId, 'files_upload')
          );
        allow update: if (
            isAttendanceFile(resource.data)
            && safeAttendanceFileUpdate(schoolId)
          ) || (
            !isAttendanceFile(resource.data)
            && hasPermission(schoolId, 'files_upload')
          );
        allow delete: if !isAttendanceFile(resource.data)
          && hasPermission(schoolId, 'files_delete');

        match /attendanceLegend/{itemId} {
          allow read: if canViewAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId));
          allow create: if (
              canManageAttendanceLegend(schoolId, nestedAttendanceFileData(schoolId, fileId))
              || canInitializeAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId))
            )
            && validAttendanceChildBase(schoolId, fileId, request.resource.data)
            && request.resource.data.createdBy == request.auth.uid;
          allow update: if canManageAttendanceLegend(schoolId, nestedAttendanceFileData(schoolId, fileId))
            && validAttendanceChildBase(schoolId, fileId, request.resource.data)
            && request.resource.data.schoolId == resource.data.schoolId
            && request.resource.data.fileId == resource.data.fileId
            && request.resource.data.updatedBy == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'label', 'shortCode', 'color', 'type', 'attendanceEffect', 'order',
              'active', 'updatedBy', 'updatedAt'
            ]);
          allow delete: if false;
        }

        match /attendanceMembers/{memberId} {
          allow read: if canViewAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId));
          allow create: if (
              canEditAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId))
              || canInitializeAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId))
            )
            && validAttendanceChildBase(schoolId, fileId, request.resource.data)
            && request.resource.data.classId == nestedAttendanceFileData(schoolId, fileId).classId
            && request.resource.data.studentId == memberId
            && studentBelongsToClass(schoolId, memberId, request.resource.data.classId)
            && request.resource.data.createdBy == request.auth.uid;
          allow update, delete: if false;
        }

        match /attendanceDays/{dayId} {
          allow read: if canViewAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId));
          allow create: if (
              canEditAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId))
              || canInitializeAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId))
            )
            && validAttendanceChildBase(schoolId, fileId, request.resource.data)
            && request.resource.data.createdBy == request.auth.uid;
          allow update: if canViewAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId))
            && (
              currentUser().role == 'principal'
              || studentPermission('attendance_manage_dates')
              || studentPermission('attendance_block_days')
            )
            && validAttendanceChildBase(schoolId, fileId, request.resource.data)
            && request.resource.data.updatedBy == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'blocked', 'blockedReason', 'updatedBy', 'updatedAt'
            ]);
          allow delete: if false;
        }

        match /attendanceRecords/{recordId} {
          allow read: if canViewAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId));
          allow create: if validAttendanceRecordWrite(
              schoolId, fileId, nestedAttendanceFileData(schoolId, fileId), request.resource.data
            )
            && recordId == request.resource.data.studentId + '__' + request.resource.data.dateKey
            && exists(/databases/$(database)/documents/schools/$(schoolId)/files/$(fileId)/attendanceMembers/$(request.resource.data.studentId))
            && exists(/databases/$(database)/documents/schools/$(schoolId)/files/$(fileId)/attendanceDays/$(request.resource.data.dateKey));
          allow update: if validAttendanceRecordWrite(
              schoolId, fileId, nestedAttendanceFileData(schoolId, fileId), request.resource.data
            )
            && request.resource.data.schoolId == resource.data.schoolId
            && request.resource.data.fileId == resource.data.fileId
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.studentId == resource.data.studentId
            && request.resource.data.dateKey == resource.data.dateKey
            && recordId == request.resource.data.studentId + '__' + request.resource.data.dateKey;
          allow delete: if false;
        }

        match /attendanceHistory/{historyId} {
          allow read: if canViewAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId));
          allow create: if canEditAttendance(schoolId, nestedAttendanceFileData(schoolId, fileId))
            && validAttendanceChildBase(schoolId, fileId, request.resource.data)
            && request.resource.data.classId == nestedAttendanceFileData(schoolId, fileId).classId
            && request.resource.data.createdBy == request.auth.uid;
          allow update, delete: if false;
        }
      }

      match /folders/{folderId} {
        allow read: if canViewSchoolResource(schoolId);
        allow create, update: if hasPermission(schoolId, 'files_upload');
        allow delete: if hasPermission(schoolId, 'files_delete');
      }

      match /fileHistory/{entryId} {
        allow read: if canViewSchoolResource(schoolId);
        allow create: if hasPermission(schoolId, 'files_upload')
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }

      match /teams/{teamId} {
        allow read: if canViewSchoolResource(schoolId);
        allow create, update, delete: if hasPermission(schoolId, 'teams_edit');
      }

      match /events/{eventId} {
        allow read: if canViewSchoolResource(schoolId);
        allow create, update, delete: if hasPermission(schoolId, 'calendar_edit');
      }

      match /holidays/{holidayId} {
        allow read: if canViewSchoolResource(schoolId);
        allow create, update, delete: if hasPermission(schoolId, 'holidays_edit');
      }

      match /categories/{categoryId} {
        allow read: if canViewSchoolResource(schoolId);
        allow create, update, delete: if hasPermission(schoolId, 'categories_edit');
      }

      match /roles/{roleId} {
        allow read: if canManageSchoolUsers(schoolId)
          || rolePermission(schoolId, 'roles.view')
          || (currentUser().customRoleIds is list && roleId in currentUser().customRoleIds);
        allow create, update, delete: if false;
      }

      match /tracks/{trackId} {
        allow read: if hasStudentDataAccess(schoolId) && isSchoolMember(schoolId);
        allow create, update, delete: if canManagePrograms(schoolId);
      }

      match /settings/{settingId} {
        allow read: if canViewSchoolResource(schoolId);
        allow create: if (
            settingId == 'academic_years'
            && validAcademicYearSettings(schoolId, request.resource.data)
          ) || canManageSchoolUsers(schoolId);
        allow update: if (
            settingId == 'academic_years'
            && validAcademicYearSettings(schoolId, request.resource.data)
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'activeAcademicYearId', 'updatedBy', 'updatedAt'
            ])
          ) || canManageSchoolUsers(schoolId);
        allow delete: if false;
      }

      match /sheets/{sheetId} {
        allow read: if canViewSchoolResource(schoolId) && (
          canEditSchoolResource(schoolId)
          || !('sharedWith' in resource.data)
          || resource.data.sharedWith.size() == 0
          || request.auth.uid in resource.data.sharedWith
          || resource.data.sharedWith.hasAny(currentUser().teamIds)
        );
        allow create, update, delete: if hasPermission(schoolId, 'data_mapping_edit');
      }
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if validConversationCreate(request.resource.data);
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.schoolId == resource.data.schoolId;
      allow delete: if signedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);
        allow create: if isConversationParticipant(conversationId)
          && request.resource.data.senderId == request.auth.uid;
        allow update: if false;
        allow delete: if isConversationParticipant(conversationId)
          && request.auth.uid == resource.data.senderId;
      }
    }

    match /announcements/{announcementId} {
      allow read: if activeUser()
        && resource.data.schoolId is string
        && isSchoolMember(resource.data.schoolId)
        && (
          resource.data.target == 'all'
          || (currentUser().teamIds is list && resource.data.target in currentUser().teamIds)
        );
      allow create: if request.resource.data.schoolId is string
        && hasPermission(request.resource.data.schoolId, 'messages_send')
        && request.resource.data.senderId == request.auth.uid;
      allow update: if false;
      allow delete: if signedIn() && (
        request.auth.uid == resource.data.senderId
        || canManageSchoolUsers(resource.data.schoolId)
      );
    }

    match /notifications/{notificationId} {
      allow read, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if false;
    }

    match /resource_permissions/{permissionId} {
      allow read: if resource.data.schoolId is string && isSchoolMember(resource.data.schoolId);
      allow create: if request.resource.data.schoolId is string
        && canManageSchoolUsers(request.resource.data.schoolId);
      allow update, delete: if resource.data.schoolId is string
        && canManageSchoolUsers(resource.data.schoolId);
    }

    match /auditLogs/{auditId} {
      allow read: if isGlobalAdmin() || (
        resource.data.schoolId is string && isSchoolPrincipal(resource.data.schoolId)
      );
      allow create, update, delete: if false;
    }

    match /securityRateLimits/{limitId} {
      allow read, write: if false;
    }

    function legacyPrimarySchoolCollection(collectionName, prefix) {
      return collectionName.matches('^' + prefix + '[A-Za-z0-9_-]+$')
        && activeUser()
        && (
          isGlobalAdmin()
          || (
            currentUser().schoolId is string
            && collectionName == prefix + currentUser().schoolId
          )
        );
    }

    function legacyDocumentSchoolAccess(collectionName, prefix, data) {
      return collectionName.matches('^' + prefix + '[A-Za-z0-9_-]+$')
        && (
          legacyPrimarySchoolCollection(collectionName, prefix)
          || (data.schoolId is string && isSchoolMember(data.schoolId))
        );
    }

    function legacyReadAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'files_', data)
        || legacyDocumentSchoolAccess(collectionName, 'file_history_', data)
        || legacyDocumentSchoolAccess(collectionName, 'folders_', data)
        || legacyDocumentSchoolAccess(collectionName, 'teams_', data)
        || legacyDocumentSchoolAccess(collectionName, 'events_', data)
        || legacyDocumentSchoolAccess(collectionName, 'holidays_', data)
        || legacyDocumentSchoolAccess(collectionName, 'categories_', data)
        || legacyDocumentSchoolAccess(collectionName, 'roles_', data)
        || legacyDocumentSchoolAccess(collectionName, 'tracks_', data)
        || legacyDocumentSchoolAccess(collectionName, 'settings_', data)
        || legacyDocumentSchoolAccess(collectionName, 'sheets_', data);
    }

    function legacySchoolId(data) {
      return data.schoolId is string ? data.schoolId : currentUser().schoolId;
    }

    function legacyWriteAllowed(collectionName, data) {
      return legacyReadAllowed(collectionName, data)
        && !isAttendanceFile(data)
        && !collectionName.matches('^(roles|settings)_.*$')
        && (isGlobalAdmin() || currentUser().role in ['principal', 'editor']);
    }

    function legacyAttendanceFileData(collectionName, fileId) {
      return get(/databases/$(database)/documents/$(collectionName)/$(fileId)).data;
    }

    function legacyAttendanceFileMatches(collectionName, fileData) {
      return collectionName.matches('^files_[A-Za-z0-9_-]+$')
        && fileData.schoolId is string
        && collectionName == 'files_' + fileData.schoolId
        && isAttendanceFile(fileData);
    }

    function legacyAttendanceCreateAllowed(collectionName, data) {
      return legacyAttendanceFileMatches(collectionName, data)
        && validAttendanceFileCreate(data.schoolId, data);
    }

    function legacyAttendanceUpdateAllowed(collectionName) {
      return legacyAttendanceFileMatches(collectionName, resource.data)
        && safeAttendanceFileUpdate(resource.data.schoolId);
    }

    function legacyAttendanceCanView(collectionName, fileId) {
      let fileData = legacyAttendanceFileData(collectionName, fileId);
      return legacyAttendanceFileMatches(collectionName, fileData)
        && canViewAttendance(fileData.schoolId, fileData);
    }

    function legacyAttendanceCanEdit(collectionName, fileId) {
      let fileData = legacyAttendanceFileData(collectionName, fileId);
      return legacyAttendanceFileMatches(collectionName, fileData)
        && canEditAttendance(fileData.schoolId, fileData);
    }

    function legacyAttendanceCanInitialize(collectionName, fileId) {
      let fileData = legacyAttendanceFileData(collectionName, fileId);
      return legacyAttendanceFileMatches(collectionName, fileData)
        && canInitializeAttendance(fileData.schoolId, fileData);
    }

    function legacyAttendanceCanManageLegend(collectionName, fileId) {
      let fileData = legacyAttendanceFileData(collectionName, fileId);
      return legacyAttendanceFileMatches(collectionName, fileData)
        && canManageAttendanceLegend(fileData.schoolId, fileData);
    }

    function legacyCanEditTasks(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'tasks_', data)
        && (
          isGlobalAdmin()
          || currentUser().role == 'principal'
          || currentUser().role == 'editor'
          || (
            currentUser().permissions is map
            && 'tasks_edit' in currentUser().permissions
            && currentUser().permissions.tasks_edit == true
          )
        );
    }

    function legacyTaskReadAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'tasks_', data)
        && isOrganizationTask(data)
        && (
          legacyCanEditTasks(collectionName, data)
          || ('createdBy' in data && data.createdBy is string && data.createdBy == request.auth.uid)
          || !('assigneeType' in data)
          || data.assigneeType == 'all_school'
          || (data.assigneeIds is list && request.auth.uid in data.assigneeIds)
          || (
            data.assigneeType == 'team'
            && currentUser().teamIds is list
            && data.assigneeTeamId in currentUser().teamIds
          )
        );
    }

    function legacyTaskCreateAllowed(collectionName, data) {
      return collectionName.matches('^tasks_[A-Za-z0-9_-]+$')
        && data.schoolId is string
        && collectionName == 'tasks_' + data.schoolId
        && validOrganizationTaskCreate(data.schoolId, data);
    }

    function legacyTaskUpdateAllowed(collectionName) {
      return collectionName.matches('^tasks_[A-Za-z0-9_-]+$')
        && (
        (
          resource.data.schoolId is string
          && collectionName == 'tasks_' + resource.data.schoolId
          && safeOrganizationTaskUpdate(resource.data.schoolId)
        )
        || (
          !('schoolId' in resource.data)
          && legacyCanEditTasks(collectionName, resource.data)
          && isOrganizationTask(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'createdBy', 'ownerId'
          ]) == false
        )
        || (
          !('schoolId' in resource.data)
          && isAssignedTask(resource.data)
          && resource.data.assigneeIds is list
          && request.auth.uid in resource.data.assigneeIds
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'completedAt', 'updatedAt'
          ])
        )
      );
    }

    function legacyTaskDeleteAllowed(collectionName, data) {
      return legacyCanEditTasks(collectionName, data) && isOrganizationTask(data);
    }

    function legacySensitiveWriteAllowed(collectionName, data) {
      return legacyReadAllowed(collectionName, data)
        && collectionName.matches('^(roles|settings)_.*$')
        && (isGlobalAdmin() || currentUser().role == 'principal');
    }

    function legacyStudentReadAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'students_', data)
        && canViewStudent(legacySchoolId(data), data);
    }

    function legacyStudentCreateAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'students_', data)
        && data.schoolId is string
        && validStudentCreate(data.schoolId, data);
    }

    function legacyStudentUpdateAllowed(collectionName) {
      let schoolId = legacySchoolId(resource.data);
      return legacyDocumentSchoolAccess(collectionName, 'students_', resource.data)
        && (
          safeDirectPromotionStudentUpdate(schoolId)
          || safeStudentUpdate(schoolId)
        );
    }

    function legacyClassReadAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'classes_', data)
        && canViewClass(legacySchoolId(data), data);
    }

    function legacyClassCreateAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'classes_', data)
        && data.schoolId is string
        && validClassCreate(data.schoolId, data);
    }

    function legacyClassUpdateAllowed(collectionName, classId) {
      return legacyDocumentSchoolAccess(collectionName, 'classes_', resource.data)
        && safeClassUpdate(legacySchoolId(resource.data), classId);
    }

    function legacyAcademicYearReadAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'academic_years_', data)
        && data.schoolId is string
        && hasStudentDataAccess(data.schoolId);
    }

    function legacyAcademicYearCreateAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'academic_years_', data)
        && data.schoolId is string
        && validAcademicYearCreate(data.schoolId, data);
    }

    function legacyAcademicYearUpdateAllowed(collectionName) {
      return legacyDocumentSchoolAccess(collectionName, 'academic_years_', resource.data)
        && safeAcademicYearUpdate(resource.data.schoolId);
    }

    function legacyEnrollmentReadAllowed(collectionName, data) {
      return legacyDocumentSchoolAccess(collectionName, 'student_enrollments_', data)
        && data.schoolId is string
        && canViewEnrollment(data.schoolId, data);
    }

    function legacyEnrollmentCreateAllowed(collectionName, enrollmentId, data) {
      return data.schoolId is string
        && collectionName == 'student_enrollments_' + data.schoolId
        && (
          validDirectPromotionEnrollmentCreate(data.schoolId, enrollmentId, data)
          || validEnrollmentCreate(data.schoolId, enrollmentId, data)
        );
    }

    function legacyEnrollmentUpdateAllowed(collectionName, enrollmentId) {
      return resource.data.schoolId is string
        && collectionName == 'student_enrollments_' + resource.data.schoolId
        && (
          safeDirectPromotionEnrollmentUpdate(resource.data.schoolId, enrollmentId)
          || safeEnrollmentUpdate(resource.data.schoolId, enrollmentId)
        );
    }

    function legacyAcademicYearSettingsWriteAllowed(collectionName, settingId, data) {
      return settingId == 'academic_years'
        && legacyDocumentSchoolAccess(collectionName, 'settings_', data)
        && data.schoolId is string
        && validAcademicYearSettings(data.schoolId, data);
    }

    function legacyRoleReadAllowed(collectionName, roleId, data) {
      let schoolId = legacySchoolId(data);
      return legacyDocumentSchoolAccess(collectionName, 'roles_', data)
        && (
          canManageSchoolUsers(schoolId)
          || rolePermission(schoolId, 'roles.view')
          || (currentUser().customRoleIds is list && roleId in currentUser().customRoleIds)
        );
    }

    function legacyTopLevelReadAllowed(collectionName, documentId, data) {
      return (
          collectionName.matches('^tasks_[A-Za-z0-9_-]+$')
          && legacyTaskReadAllowed(collectionName, data)
        ) || (
          collectionName.matches('^academic_years_[A-Za-z0-9_-]+$')
          && legacyAcademicYearReadAllowed(collectionName, data)
        ) || (
          collectionName.matches('^student_enrollments_[A-Za-z0-9_-]+$')
          && legacyEnrollmentReadAllowed(collectionName, data)
        ) || (
          collectionName.matches('^students_[A-Za-z0-9_-]+$')
          && legacyStudentReadAllowed(collectionName, data)
        ) || (
          collectionName.matches('^classes_[A-Za-z0-9_-]+$')
          && (
          classRolePermission(legacySchoolId(data), 'classes.view', documentId)
          || classRolePermission(legacySchoolId(data), 'students.view', documentId)
          || legacyClassReadAllowed(collectionName, data)
          )
        ) || (
          collectionName.matches('^roles_[A-Za-z0-9_-]+$')
          && legacyRoleReadAllowed(collectionName, documentId, data)
        ) || (
          !collectionName.matches('^(tasks|academic_years|student_enrollments|students|classes|roles|personal_files|skill_catalog)_[A-Za-z0-9_-]+$')
          && legacyReadAllowed(collectionName, data)
        );
    }

    function legacyTopLevelCreateAllowed(collectionName, documentId, data) {
      return (
          collectionName.matches('^tasks_[A-Za-z0-9_-]+$')
          && legacyTaskCreateAllowed(collectionName, data)
        ) || (
          collectionName.matches('^academic_years_[A-Za-z0-9_-]+$')
          && legacyAcademicYearCreateAllowed(collectionName, data)
        ) || (
          collectionName.matches('^student_enrollments_[A-Za-z0-9_-]+$')
          && legacyEnrollmentCreateAllowed(collectionName, documentId, data)
        ) || (
          collectionName.matches('^students_[A-Za-z0-9_-]+$')
          && legacyStudentCreateAllowed(collectionName, data)
        ) || (
          collectionName.matches('^classes_[A-Za-z0-9_-]+$')
          && legacyClassCreateAllowed(collectionName, data)
        ) || (
          collectionName.matches('^files_[A-Za-z0-9_-]+$')
          && isAttendanceFile(data)
          && legacyAttendanceCreateAllowed(collectionName, data)
        ) || (
          collectionName.matches('^settings_[A-Za-z0-9_-]+$')
          && documentId == 'academic_years'
          && (
          legacyAcademicYearSettingsWriteAllowed(collectionName, documentId, data)
          || legacySensitiveWriteAllowed(collectionName, data)
          )
        ) || (
          collectionName.matches('^settings_[A-Za-z0-9_-]+$')
          && documentId != 'academic_years'
          && legacySensitiveWriteAllowed(collectionName, data)
        ) || (
          !collectionName.matches('^(tasks|academic_years|student_enrollments|students|classes|roles|settings|personal_files|skill_catalog)_[A-Za-z0-9_-]+$')
          && !(collectionName.matches('^files_[A-Za-z0-9_-]+$') && isAttendanceFile(data))
          && legacyWriteAllowed(collectionName, data)
        );
    }

    function legacyTopLevelUpdateAllowed(collectionName, documentId) {
      return (
          collectionName.matches('^tasks_[A-Za-z0-9_-]+$')
          && legacyTaskUpdateAllowed(collectionName)
        ) || (
          collectionName.matches('^academic_years_[A-Za-z0-9_-]+$')
          && legacyAcademicYearUpdateAllowed(collectionName)
        ) || (
          collectionName.matches('^student_enrollments_[A-Za-z0-9_-]+$')
          && legacyEnrollmentUpdateAllowed(collectionName, documentId)
        ) || (
          collectionName.matches('^students_[A-Za-z0-9_-]+$')
          && legacyStudentUpdateAllowed(collectionName)
        ) || (
          collectionName.matches('^classes_[A-Za-z0-9_-]+$')
          && legacyClassUpdateAllowed(collectionName, documentId)
        ) || (
          collectionName.matches('^files_[A-Za-z0-9_-]+$')
          && isAttendanceFile(resource.data)
          && legacyAttendanceUpdateAllowed(collectionName)
        ) || (
          collectionName.matches('^settings_[A-Za-z0-9_-]+$')
          && documentId == 'academic_years'
          && (
          (
            legacyAcademicYearSettingsWriteAllowed(
              collectionName,
              documentId,
              request.resource.data
            )
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'activeAcademicYearId', 'updatedBy', 'updatedAt'
            ])
          )
          || legacySensitiveWriteAllowed(collectionName, resource.data)
          )
        ) || (
          collectionName.matches('^settings_[A-Za-z0-9_-]+$')
          && documentId != 'academic_years'
          && legacySensitiveWriteAllowed(collectionName, resource.data)
        ) || (
          !collectionName.matches('^(tasks|academic_years|student_enrollments|students|classes|roles|settings|personal_files|skill_catalog)_[A-Za-z0-9_-]+$')
          && !(collectionName.matches('^files_[A-Za-z0-9_-]+$') && isAttendanceFile(resource.data))
          && legacyWriteAllowed(collectionName, resource.data)
        );
    }

    function legacyTopLevelDeleteAllowed(collectionName, data) {
      return (
          collectionName.matches('^tasks_[A-Za-z0-9_-]+$')
          && legacyTaskDeleteAllowed(collectionName, data)
        ) || (
          collectionName.matches('^settings_[A-Za-z0-9_-]+$')
          && legacySensitiveWriteAllowed(collectionName, data)
        ) || (
          !collectionName.matches('^(tasks|academic_years|student_enrollments|roles|settings|personal_files|skill_catalog)_[A-Za-z0-9_-]+$')
          && legacyWriteAllowed(collectionName, data)
        );
    }

    match /{legacyCollection}/{documentId} {
      allow read: if (
          legacyCollection.matches('^personal_files_[A-Za-z0-9_-]+$')
          && resource.data.schoolId is string
          && legacyCollection == 'personal_files_' + resource.data.schoolId
          && resource.data.studentId == documentId
          && canViewPersonalFile(resource.data.schoolId, documentId)
        ) || (
          legacyCollection.matches('^skill_catalog_[A-Za-z0-9_-]+$')
          && resource.data.schoolId is string
          && legacyCollection == 'skill_catalog_' + resource.data.schoolId
          && canViewSkillCatalog(resource.data.schoolId)
        ) || legacyTopLevelReadAllowed(legacyCollection, documentId, resource.data);
      allow create: if (
          legacyCollection.matches('^personal_files_[A-Za-z0-9_-]+$')
          && validPersonalFileCreate(
            legacyCollection,
            documentId,
            request.resource.data
          )
        ) || (
          legacyCollection.matches('^student_enrollments_[A-Za-z0-9_-]+$')
          && request.resource.data.schoolId is string
          && legacyCollection == 'student_enrollments_' + request.resource.data.schoolId
          && validDirectPromotionEnrollmentCreate(
            request.resource.data.schoolId,
            documentId,
            request.resource.data
          )
        ) || (
          legacyCollection.matches('^student_enrollments_[A-Za-z0-9_-]+$')
          && request.resource.data.schoolId is string
          && legacyCollection == 'student_enrollments_' + request.resource.data.schoolId
          && validDirectTeacherEnrollmentCreate(
            request.resource.data.schoolId,
            documentId,
            request.resource.data
          )
        ) || (
          legacyCollection.matches('^students_[A-Za-z0-9_-]+$')
          && request.resource.data.schoolId is string
          && legacyCollection == 'students_' + request.resource.data.schoolId
          && validDirectTeacherStudentCreate(
            request.resource.data.schoolId,
            request.resource.data
          )
        ) || legacyTopLevelCreateAllowed(
          legacyCollection,
          documentId,
          request.resource.data
        );
      allow update: if (
          legacyCollection.matches('^student_enrollments_[A-Za-z0-9_-]+$')
          && resource.data.schoolId is string
          && legacyCollection == 'student_enrollments_' + resource.data.schoolId
          && safeDirectPromotionEnrollmentUpdate(resource.data.schoolId, documentId)
        ) || (
          legacyCollection.matches('^student_enrollments_[A-Za-z0-9_-]+$')
          && resource.data.schoolId is string
          && legacyCollection == 'student_enrollments_' + resource.data.schoolId
          && safeDirectLifecycleEnrollmentUpdate(resource.data.schoolId, documentId)
        ) || (
          legacyCollection.matches('^students_[A-Za-z0-9_-]+$')
          && resource.data.schoolId is string
          && legacyCollection == 'students_' + resource.data.schoolId
          && safeDirectPromotionStudentUpdate(resource.data.schoolId)
        ) || (
          legacyCollection.matches('^students_[A-Za-z0-9_-]+$')
          && resource.data.schoolId is string
          && legacyCollection == 'students_' + resource.data.schoolId
          && safeDirectLifecycleStudentUpdate(resource.data.schoolId)
        ) || (
          legacyCollection.matches('^students_[A-Za-z0-9_-]+$')
          && resource.data.schoolId is string
          && legacyCollection == 'students_' + resource.data.schoolId
          && safeDirectScopedRoleStudentUpdate(resource.data.schoolId)
        ) || legacyTopLevelUpdateAllowed(legacyCollection, documentId);
      allow delete: if legacyTopLevelDeleteAllowed(legacyCollection, resource.data);
    }

    match /{legacyCollection}/{studentId}/{kind}/{itemId} {
      allow read: if legacyCollection.matches('^personal_files_[A-Za-z0-9_-]+$')
        && kind in ['documents', 'credentials', 'experiences', 'skills', 'recommendations']
        && resource.data.schoolId is string
        && legacyCollection == 'personal_files_' + resource.data.schoolId
        && resource.data.studentId == studentId
        && canViewPersonalFile(resource.data.schoolId, studentId);
      allow create, update, delete: if false;
    }

    match /{legacyCollection}/{studentId}/cvDocuments/{documentId} {
      allow read: if legacyCollection.matches('^personal_files_[A-Za-z0-9_-]+$')
        && resource.data.schoolId is string
        && legacyCollection == 'personal_files_' + resource.data.schoolId
        && resource.data.studentId == studentId
        && canViewCv(resource.data.schoolId, studentId);
      allow create, update, delete: if false;

      match /versions/{versionId} {
        allow read: if legacyCollection.matches('^personal_files_[A-Za-z0-9_-]+$')
          && resource.data.schoolId is string
          && legacyCollection == 'personal_files_' + resource.data.schoolId
          && resource.data.studentId == studentId
          && canViewCv(resource.data.schoolId, studentId);
        allow create, update, delete: if false;

        match /exports/{exportId} {
          allow read: if legacyCollection.matches('^personal_files_[A-Za-z0-9_-]+$')
            && resource.data.schoolId is string
            && legacyCollection == 'personal_files_' + resource.data.schoolId
            && resource.data.studentId == studentId
            && canViewCv(resource.data.schoolId, studentId);
          allow create, update, delete: if false;
        }
      }
    }

    match /{templateCollection}/{templateId} {
      allow read: if templateCollection.matches('^cv_templates_[A-Za-z0-9_-]+$')
        && resource.data.schoolId is string
        && templateCollection == 'cv_templates_' + resource.data.schoolId
        && canReadCvTemplate(resource.data.schoolId, resource.data);
      allow create, update, delete: if false;
    }

    match /{legacyCollection}/{entityId}/history/{historyId} {
      allow read: if (
          legacyCollection.matches('^students_[A-Za-z0-9_-]+$')
          && canViewStudent(
            legacySchoolId(get(/databases/$(database)/documents/$(legacyCollection)/$(entityId)).data),
            get(/databases/$(database)/documents/$(legacyCollection)/$(entityId)).data
          )
        ) || (
          legacyCollection.matches('^classes_[A-Za-z0-9_-]+$')
          && canViewClass(
            legacySchoolId(get(/databases/$(database)/documents/$(legacyCollection)/$(entityId)).data),
            get(/databases/$(database)/documents/$(legacyCollection)/$(entityId)).data
          )
        );
      allow create: if (
          legacyCollection.matches('^students_[A-Za-z0-9_-]+$')
          && (
            validDirectPromotionHistoryCreate(
              request.resource.data.schoolId,
              entityId,
              request.resource.data
            )
            || validDirectTeacherHistoryCreate(
              request.resource.data.schoolId,
              entityId,
              request.resource.data
            )
            || validDirectLifecycleHistoryCreate(
              request.resource.data.schoolId,
              entityId,
              request.resource.data
            )
            || validStudentHistoryCreate(
              request.resource.data.schoolId,
              entityId,
              getAfter(/databases/$(database)/documents/$(legacyCollection)/$(entityId)).data,
              request.resource.data
            )
          )
        ) || (
          legacyCollection.matches('^classes_[A-Za-z0-9_-]+$')
          && request.resource.data.classId == entityId
          && request.resource.data.createdBy == request.auth.uid
          && hasStudentDataAccess(request.resource.data.schoolId)
          && (
            currentUser().role == 'principal'
            || studentPermission('classes_update')
            || studentPermission('classes_archive')
            || studentPermission('classes_assign_teacher')
          )
        );
      allow update, delete: if false;
    }

    match /{legacyCollection}/{fileId}/attendanceLegend/{itemId} {
      allow read: if legacyAttendanceCanView(legacyCollection, fileId);
      allow create: if (
          legacyAttendanceCanManageLegend(legacyCollection, fileId)
          || legacyAttendanceCanInitialize(legacyCollection, fileId)
        )
        && validAttendanceChildBase(
          legacyAttendanceFileData(legacyCollection, fileId).schoolId,
          fileId,
          request.resource.data
        )
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if legacyAttendanceCanManageLegend(legacyCollection, fileId)
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.fileId == resource.data.fileId
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'label', 'shortCode', 'color', 'type', 'attendanceEffect', 'order',
          'active', 'updatedBy', 'updatedAt'
        ]);
      allow delete: if false;
    }

    match /{legacyCollection}/{fileId}/attendanceMembers/{memberId} {
      allow read: if legacyAttendanceCanView(legacyCollection, fileId);
      allow create: if (
          legacyAttendanceCanEdit(legacyCollection, fileId)
          || legacyAttendanceCanInitialize(legacyCollection, fileId)
        )
        && validAttendanceChildBase(
          legacyAttendanceFileData(legacyCollection, fileId).schoolId,
          fileId,
          request.resource.data
        )
        && request.resource.data.classId == legacyAttendanceFileData(legacyCollection, fileId).classId
        && request.resource.data.studentId == memberId
        && studentBelongsToClass(
          legacyAttendanceFileData(legacyCollection, fileId).schoolId,
          memberId,
          request.resource.data.classId
        )
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /{legacyCollection}/{fileId}/attendanceDays/{dayId} {
      allow read: if legacyAttendanceCanView(legacyCollection, fileId);
      allow create: if (
          legacyAttendanceCanEdit(legacyCollection, fileId)
          || legacyAttendanceCanInitialize(legacyCollection, fileId)
        )
        && validAttendanceChildBase(
          legacyAttendanceFileData(legacyCollection, fileId).schoolId,
          fileId,
          request.resource.data
        )
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if legacyAttendanceCanView(legacyCollection, fileId)
        && (
          currentUser().role == 'principal'
          || studentPermission('attendance_manage_dates')
          || studentPermission('attendance_block_days')
        )
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.fileId == resource.data.fileId
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'blocked', 'blockedReason', 'updatedBy', 'updatedAt'
        ]);
      allow delete: if false;
    }

    match /{legacyCollection}/{fileId}/attendanceRecords/{recordId} {
      allow read: if legacyAttendanceCanView(legacyCollection, fileId);
      allow create: if validAttendanceRecordWrite(
          legacyAttendanceFileData(legacyCollection, fileId).schoolId,
          fileId,
          legacyAttendanceFileData(legacyCollection, fileId),
          request.resource.data
        )
        && recordId == request.resource.data.studentId + '__' + request.resource.data.dateKey
        && exists(/databases/$(database)/documents/$(legacyCollection)/$(fileId)/attendanceMembers/$(request.resource.data.studentId))
        && exists(/databases/$(database)/documents/$(legacyCollection)/$(fileId)/attendanceDays/$(request.resource.data.dateKey));
      allow update: if validAttendanceRecordWrite(
          legacyAttendanceFileData(legacyCollection, fileId).schoolId,
          fileId,
          legacyAttendanceFileData(legacyCollection, fileId),
          request.resource.data
        )
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.fileId == resource.data.fileId
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.dateKey == resource.data.dateKey
        && recordId == request.resource.data.studentId + '__' + request.resource.data.dateKey;
      allow delete: if false;
    }

    match /{legacyCollection}/{fileId}/attendanceHistory/{historyId} {
      allow read: if legacyAttendanceCanView(legacyCollection, fileId);
      allow create: if legacyAttendanceCanEdit(legacyCollection, fileId)
        && validAttendanceChildBase(
          legacyAttendanceFileData(legacyCollection, fileId).schoolId,
          fileId,
          request.resource.data
        )
        && request.resource.data.classId == legacyAttendanceFileData(legacyCollection, fileId).classId
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /{legacyCollection}/{studentId}/notes/{noteId} {
      allow read: if legacyCollection.matches('^students_[A-Za-z0-9_-]+$')
        && canReadStudentNote(
          legacySchoolId(get(/databases/$(database)/documents/$(legacyCollection)/$(studentId)).data),
          get(/databases/$(database)/documents/$(legacyCollection)/$(studentId)).data,
          resource.data
        );
      allow create: if legacyCollection.matches('^students_[A-Za-z0-9_-]+$')
        && request.resource.data.studentId == studentId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.visibility in ['class_staff', 'school_admin']
        && canViewStudent(
          request.resource.data.schoolId,
          get(/databases/$(database)/documents/$(legacyCollection)/$(studentId)).data
        )
        && (
          canAddStudentNote(
            request.resource.data.schoolId,
            get(/databases/$(database)/documents/$(legacyCollection)/$(studentId)).data
          )
        );
      allow update, delete: if false;
    }

    match /{legacyCollection}/{taskId}/chat/{messageId} {
      allow read: if legacyTaskReadAllowed(
        legacyCollection,
        get(/databases/$(database)/documents/$(legacyCollection)/$(taskId)).data
      );
      allow create: if legacyTaskReadAllowed(
          legacyCollection,
          get(/databases/$(database)/documents/$(legacyCollection)/$(taskId)).data
        )
        && request.resource.data.authorId == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth.uid == resource.data.authorId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
